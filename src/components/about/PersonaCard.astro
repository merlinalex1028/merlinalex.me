---
import PersonaStats from './PersonaStats.astro';
import SkillBars from './SkillBars.astro';
import PersonaFavorites from './PersonaFavorites.astro';
import PersonaQA from './PersonaQA.astro';

const { persona } = Astro.props;
const hasAnyStat = persona?.mbti || persona?.zodiac || persona?.blood;
const hasSkills = Array.isArray(persona?.skills) && persona.skills.length > 0;
const hasFavorites = (persona?.favorites?.anime?.length > 0) || (persona?.favorites?.characters?.length > 0);
const hasQa = Array.isArray(persona?.qa) && persona.qa.length > 0;
---

<article class="persona-card">
  {persona?.avatar && (
    <header class="persona-header">
      <img
        class="persona-avatar"
        src={persona.avatar}
        alt={`${persona?.name?.zh ?? '我'}的头像`}
        width="200"
        height="200"
        loading="lazy"
        decoding="async"
      />
      <h1>{persona?.name?.zh}</h1>
      {persona?.name?.romaji && <p class="persona-romaji">({persona.name.romaji})</p>}
      {persona?.tagline && <p class="persona-bio">{persona.tagline}</p>}
    </header>
  )}

  {!persona?.avatar && persona?.name?.zh && (
    <header class="persona-header">
      <h1>{persona.name.zh}</h1>
      {persona?.name?.romaji && <p class="persona-romaji">({persona.name.romaji})</p>}
      {persona?.tagline && <p class="persona-bio">{persona.tagline}</p>}
    </header>
  )}

  {hasAnyStat && (
    <PersonaStats
      mbti={persona.mbti}
      zodiac={persona.zodiac}
      blood={persona.blood}
    />
  )}

  {hasSkills && <SkillBars skills={persona.skills} />}

  {hasFavorites && (
    <PersonaFavorites
      anime={persona.favorites?.anime}
      characters={persona.favorites?.characters}
    />
  )}

  {hasQa && <PersonaQA qa={persona.qa} />}
</article>

<style>
  .persona-card {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-2xl, 3rem) 1rem;
  }
  .persona-header {
    text-align: center;
    margin-bottom: var(--space-2xl, 3rem);
  }
  .persona-avatar {
    display: block;
    width: 200px;
    height: 200px;
    border-radius: 9999px;
    border: 4px solid var(--color-accent-subtle);
    object-fit: cover;
    margin: 0 auto var(--space-md, 1rem) auto;
    background: linear-gradient(135deg, var(--color-accent-subtle), var(--color-accent));
  }
  .persona-header h1 {
    font-size: 24px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-fg);
    margin: 0 0 0.25rem 0;
  }
  .persona-romaji {
    font-size: 14px;
    color: var(--color-fg-muted);
    margin: 0 0 var(--space-md, 1rem) 0;
  }
  .persona-bio {
    font-size: 16px;
    line-height: 1.5;
    color: var(--color-fg);
    font-style: italic;
    margin: 0;
    max-width: 32em;
    margin-left: auto;
    margin-right: auto;
  }
</style>
