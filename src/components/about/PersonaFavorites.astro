---
const { anime = [], characters = [] } = Astro.props;
const hasAnime = anime.length > 0;
const hasCharacters = characters.length > 0;
---

<section class="persona-favorites">
  {hasAnime && (
    <div class="fav-col">
      <h2>最喜欢的动画</h2>
      <ul>
        {anime.map((a: any) => (
          <li>
            <span class="fav-title">{a.title}</span>
            {a.year && <span class="fav-year">({a.year})</span>}
          </li>
        ))}
      </ul>
    </div>
  )}
  {hasCharacters && (
    <div class="fav-col">
      <h2>最喜欢的角色</h2>
      <ul>
        {characters.map((c: any) => (
          <li>
            <span class="fav-title">{c.name}</span>
            {c.source && <span class="fav-source">《{c.source}》</span>}
          </li>
        ))}
      </ul>
    </div>
  )}
</section>

<style>
  .persona-favorites {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg, 1.5rem);
    margin-bottom: var(--space-xl, 2rem);
  }
  @media (min-width: 768px) {
    .persona-favorites {
      grid-template-columns: 1fr 1fr;
    }
  }
  .fav-col h2 {
    font-size: 20px;
    font-weight: 600;
    color: var(--color-fg);
    margin: 0 0 var(--space-md, 1rem) 0;
  }
  .fav-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm, 0.5rem);
  }
  .fav-col li {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 12px);
    padding: var(--space-sm, 0.5rem) var(--space-md, 1rem);
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .fav-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-fg);
  }
  .fav-year,
  .fav-source {
    font-size: 12px;
    color: var(--color-fg-muted);
  }
</style>
