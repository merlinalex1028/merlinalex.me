---
import type { CollectionEntry } from 'astro:content';

interface Props {
  articles: CollectionEntry<'articles'>[];
}

const { articles } = Astro.props;

// Group articles by year (sorted descending)
const yearGroups = new Map<number, CollectionEntry<'articles'>[]>();

for (const article of articles) {
  const year = article.data.publishedAt.getFullYear();
  const group = yearGroups.get(year) ?? [];
  group.push(article);
  yearGroups.set(year, group);
}

// Sort years descending
const sortedYears = [...yearGroups.keys()].sort((a, b) => b - a);

function formatDate(date: Date): string {
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${month}-${day}`;
}
---

<div class="archive-list">
  {sortedYears.map((year) => {
    const yearArticles = yearGroups.get(year) ?? [];
    return (
      <section class="archive-year">
        <h2 class="year-heading">{year}</h2>
        <ul class="year-articles">
          {yearArticles.map((article) => (
            <li class="article-row">
              <time
                class="article-date"
                datetime={article.data.publishedAt.toISOString()}
              >
                {formatDate(article.data.publishedAt)}
              </time>
              <a href={`/articles/${article.id}`} class="article-link">
                {article.data.title}
              </a>
              {article.data.category && (
                <span class="article-category">{article.data.category}</span>
              )}
            </li>
          ))}
        </ul>
      </section>
    );
  })}
</div>

<style>
  .archive-list {
    max-width: 768px;
    margin: 0 auto;
    padding: var(--space-md, 1rem) 0;
  }

  .archive-year {
    margin-bottom: var(--space-lg, 1.5rem);
  }

  .year-heading {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-fg);
    margin-bottom: var(--space-sm, 0.5rem);
    padding-bottom: 0.25rem;
    border-bottom: 2px solid var(--color-accent);
    display: inline-block;
  }

  .year-articles {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .article-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .article-row:last-child {
    border-bottom: none;
  }

  .article-date {
    font-size: 0.8rem;
    color: var(--color-fg-muted);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
    min-width: 3rem;
  }

  .article-link {
    color: var(--color-fg);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color var(--duration-fast, 0.15s) var(--easing-default, ease);
    flex: 1;
  }

  .article-link:hover,
  .article-link:focus-visible {
    color: var(--color-accent);
  }

  .article-category {
    font-size: 0.7rem;
    color: var(--color-fg-muted);
    background: var(--color-surface);
    padding: 0.125rem 0.5rem;
    border-radius: var(--radius-sm, 4px);
    flex-shrink: 0;
  }
</style>
