---
interface Props {
  tagCounts: Record<string, number>;
}

const { tagCounts } = Astro.props;

// Filter out tags with count <= 1 (hide 0 and 1-post tags per D-06)
const filteredTags = Object.entries(tagCounts).filter(([, count]) => count > 1);

// Sort by count descending for visual consistency
const sortedTags = filteredTags.sort(([, a], [, b]) => b - a);

// Compute font sizes using percentile scaling (14px-28px range)
const counts = sortedTags.map(([, count]) => count);
const min = counts.length > 0 ? Math.min(...counts) : 0;
const max = counts.length > 0 ? Math.max(...counts) : 1;
const range = max - min || 1;

const tagsWithSize = sortedTags.map(([tag, count]) => ({
  tag,
  count,
  fontSize: 14 + ((count - min) / range) * 14,
}));
---

{tagsWithSize.length > 0 ? (
  <div class="tag-cloud" aria-label="标签云">
    {tagsWithSize.map(({ tag, count, fontSize }) => (
      <a
        href={`/articles?tag=${encodeURIComponent(tag)}`}
        class="tag-item"
        style={`font-size: ${fontSize}px`}
        title={`${tag} (${count} 篇)`}
      >
        {tag}
      </a>
    ))}
  </div>
) : (
  <p class="tag-cloud-empty">暂无标签</p>
)}

<style>
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    justify-content: center;
    align-items: center;
    padding: var(--space-md, 1rem);
  }

  .tag-item {
    color: var(--color-fg-muted);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm, 6px);
    transition: color var(--duration-fast, 0.15s) var(--easing-default, ease),
      background var(--duration-fast, 0.15s) var(--easing-default, ease);
    line-height: 1.4;
  }

  .tag-item:hover,
  .tag-item:focus-visible {
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
  }

  .tag-cloud-empty {
    text-align: center;
    color: var(--color-fg-muted);
    font-size: 0.875rem;
    padding: var(--space-md, 1rem);
  }
</style>
