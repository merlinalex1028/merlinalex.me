---
import type { CollectionEntry } from 'astro:content';
import StickyBadge from './StickyBadge.astro';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { title, description, publishedAt, category, sticky } = article.data;
---

<li class="article-item">
  <a href={`/articles/${article.id}`} class="article-link">
    <div class="article-content">
      <div class="article-header">
        {sticky && <StickyBadge />}
        <h3 class="article-title">{title}</h3>
      </div>
      {description && <p class="article-excerpt">{description}</p>}
      <div class="article-meta">
        <time datetime={publishedAt.toISOString()}>
          {publishedAt.toLocaleDateString('zh-CN')}
        </time>
        {category && <span class="category-pill">{category}</span>}
      </div>
    </div>
  </a>
</li>

<style>
  .article-item {
    list-style: none;
  }

  .article-link {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 1rem;
    text-decoration: none;
    color: inherit;
    transition:
      border-color var(--duration-fast, 150ms) var(--easing-default, ease),
      box-shadow var(--duration-base, 250ms) var(--easing-default, ease);
  }

  .article-link:hover,
  .article-link:focus-visible {
    border-color: var(--color-accent);
    box-shadow: 0 4px 16px rgba(255, 107, 157, 0.12);
  }

  .article-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .article-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .article-title {
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-fg);
    margin: 0;
  }

  .article-excerpt {
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-fg-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 14px;
    color: var(--color-fg-muted);
  }

  .category-pill {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 9999px;
    background: var(--color-accent-subtle);
    color: var(--color-accent);
    font-size: 14px;
  }
</style>
