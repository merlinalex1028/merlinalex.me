---
import type { CollectionEntry } from 'astro:content';

interface Props {
  prev?: CollectionEntry<'articles'>;
  next?: CollectionEntry<'articles'>;
}

const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav class="article-nav" aria-label="文章导航">
    {prev ? (
      <a href={`/articles/${prev.id}`} class="nav-card prev">
        <span class="nav-label">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
          上一篇
        </span>
        <span class="nav-title">{prev.data.title}</span>
      </a>
    ) : <div />}
    {next ? (
      <a href={`/articles/${next.id}`} class="nav-card next">
        <span class="nav-label">
          下一篇
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </span>
        <span class="nav-title">{next.data.title}</span>
      </a>
    ) : <div />}
  </nav>
)}

<style>
  .article-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 2rem;
  }
  .nav-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem;
    border-radius: 16px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    transition:
      border-color var(--duration-fast, 150ms) var(--easing-default, ease),
      box-shadow var(--duration-base, 250ms) var(--easing-default, ease);
  }
  .nav-card:hover,
  .nav-card:focus-visible {
    border-color: var(--color-accent);
    box-shadow: 0 4px 16px rgba(255, 107, 157, 0.12);
  }
  .nav-card.next {
    text-align: right;
  }
  .nav-label {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 14px;
    color: var(--color-fg-muted);
  }
  .nav-card.next .nav-label {
    justify-content: flex-end;
  }
  .nav-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-fg);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.4;
  }
</style>
