---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;

const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);
---

<div class="share-buttons">
  <button
    type="button"
    class="share-btn"
    aria-label="复制链接"
    data-copy-url={url}
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/>
      <path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/>
    </svg>
  </button>
  <a
    href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
    target="_blank"
    rel="noopener noreferrer"
    class="share-btn"
    aria-label="分享到 Twitter/X"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
  </a>
  <a
    href={`https://service.weibo.com/share/share.php?title=${encodedTitle}&url=${encodedUrl}`}
    target="_blank"
    rel="noopener noreferrer"
    class="share-btn"
    aria-label="分享到微博"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
      <path d="M10.098 20.323c-3.977.391-7.414-1.406-7.672-4.02-.259-2.609 2.759-5.047 6.74-5.441 3.979-.394 7.413 1.404 7.671 4.018.259 2.6-2.759 5.049-6.739 5.443zM9.05 17.219c-.384.616-1.208.884-1.829.602-.612-.279-.793-.991-.406-1.593.379-.595 1.176-.86 1.793-.588.625.28.825.985.442 1.579zm1.27-1.627c-.141.237-.449.353-.689.253-.236-.09-.307-.361-.158-.597.142-.234.453-.351.689-.243.236.1.304.362.158.587zm.476-2.081c-1.607-.449-3.428.39-4.14 1.887-.728 1.528-.131 3.236 1.46 3.721 1.652.499 3.562-.353 4.263-1.914.687-1.532.042-3.243-1.583-3.694zM20.514 11.18c-.269-.084-.449-.143-.311-.516.301-.812.332-1.505.006-1.997-.613-.921-2.286-.873-4.193-.026 0 0-.601.264-.447-.214.297-.945.252-1.738-.212-2.198-1.061-1.05-3.882.04-6.301 2.438-1.812 1.795-2.857 3.716-2.857 5.391 0 3.182 4.085 5.116 8.065 5.116 5.231 0 8.693-3.035 8.693-5.445 0-1.454-1.228-2.289-2.443-2.556z"/>
    </svg>
  </a>
</div>

<script is:inline>
  (function () {
    document.querySelectorAll('[data-copy-url]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var url = btn.getAttribute('data-copy-url');
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(url).then(function () {
            showCopyFeedback(btn);
          });
        } else {
          var textarea = document.createElement('textarea');
          textarea.value = url;
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          document.body.appendChild(textarea);
          textarea.select();
          document.execCommand('copy');
          document.body.removeChild(textarea);
          showCopyFeedback(btn);
        }
      });
    });

    function showCopyFeedback(btn) {
      var tooltip = document.createElement('span');
      tooltip.className = 'share-tooltip';
      tooltip.textContent = '已复制链接!';
      btn.parentElement.appendChild(tooltip);
      setTimeout(function () {
        tooltip.remove();
      }, 2000);
    }
  })();
</script>

<style>
  .share-buttons {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 2rem 0;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-fg-muted);
    text-decoration: none;
    cursor: pointer;
    transition:
      background var(--duration-fast, 150ms) var(--easing-default, ease),
      border-color var(--duration-fast, 150ms) var(--easing-default, ease),
      color var(--duration-fast, 150ms) var(--easing-default, ease);
  }
  .share-btn:hover {
    background: var(--color-accent-subtle);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>

<style is:global>
  .share-tooltip {
    font-size: 14px;
    color: var(--color-accent);
    margin-left: 4px;
    animation: share-fade 2s ease forwards;
  }
  @keyframes share-fade {
    0%, 70% { opacity: 1; }
    100% { opacity: 0; }
  }
</style>
