---
interface Props {
  tags: string[];
  selected: string | null;
  counts?: Record<string, number>;
  total?: number;
}

const { tags, selected, counts = {}, total = tags.length || 1 } = Astro.props;
---

<nav class="tag-panel" aria-label="文章标签筛选">
  <span class="tag-title">文章分类</span>
  <div class="tag-chips">
    <a
      href="/articles"
      class:list={['chip', 'all-chip', { active: selected === null }]}
      aria-current={selected === null ? 'page' : undefined}
    >
      <span class="chip-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="m12 3 2.45 5.2 5.55.85-4 4.05.95 5.72L12 16.1l-4.95 2.72L8 13.1 4 9.05l5.55-.85L12 3Z" />
        </svg>
      </span>
      全部 ({total})
    </a>
    {tags.map(tag => (
      <a
        href={`/articles?tag=${encodeURIComponent(tag)}`}
        class:list={['chip', { active: selected === tag }]}
        aria-current={selected === tag ? 'page' : undefined}
      >
        <span class="chip-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M6 4h8l4 4v12H6V4Zm7 0v5h5" />
          </svg>
        </span>
        {tag} ({counts[tag] ?? 0})
      </a>
    ))}
  </div>
</nav>

<style>
  .tag-panel {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 3vw, 2rem);
    margin-bottom: 1.35rem;
    padding: 1.45rem 2.1rem;
    overflow: hidden;
    border: 1px solid rgba(207, 199, 248, 0.82);
    border-radius: 22px;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.58)),
      var(--color-surface);
    box-shadow:
      0 18px 45px rgba(113, 88, 212, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.92);
  }

  .tag-title {
    flex: 0 0 auto;
    color: #10194d;
    font-size: 1.12rem;
    font-weight: 900;
  }

  .tag-chips {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    min-width: 0;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    white-space: nowrap;
  }

  .tag-chips::-webkit-scrollbar {
    display: none;
  }

  .chip {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    gap: 0.58rem;
    min-height: 54px;
    padding: 0 1.35rem;
    border-radius: 9999px;
    border: 1px solid rgba(211, 205, 244, 0.88);
    background: rgba(255, 255, 255, 0.62);
    color: #28336b;
    font-size: 1rem;
    font-weight: 850;
    text-decoration: none;
    box-shadow:
      0 10px 20px rgba(100, 87, 190, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    transition:
      transform var(--duration-fast) var(--easing-default),
      color var(--duration-fast) var(--easing-default),
      border-color var(--duration-fast) var(--easing-default);
  }

  .chip:hover,
  .chip:focus-visible {
    transform: translateY(-1px);
    border-color: rgba(143, 108, 244, 0.55);
  }

  .chip.active {
    color: #fff;
    border-color: transparent;
    background: linear-gradient(135deg, #9166ff, #ed5db8);
    box-shadow:
      0 14px 26px rgba(168, 80, 221, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.34);
  }

  .chip-icon {
    display: inline-grid;
    width: 22px;
    height: 22px;
    place-items: center;
    color: #7b55f5;
  }

  .chip.active .chip-icon {
    color: currentColor;
  }

  .chip-icon svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .all-chip .chip-icon svg {
    fill: currentColor;
    stroke: none;
  }

  @media (max-width: 760px) {
    .tag-panel {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.9rem;
      padding: 1.15rem;
      border-radius: 18px;
    }

    .tag-chips {
      width: 100%;
    }
  }
</style>
