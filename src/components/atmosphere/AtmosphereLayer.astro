---
/**
 * AtmosphereLayer — fixed-position wrapper for all atmosphere islands.
 *
 * - position: fixed; inset: 0 — covers the viewport
 * - pointer-events: none — does not block page scroll/clicks
 * - z-index: 50 — above content, below modals
 * - Child effect islands are hidden when data-atmo="off" via CSS gate in global.css
 * - Child islands set pointer-events: auto on their interactive elements
 */
---

<div class="atmo-layer">
  <slot />
</div>

<style>
  .atmo-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 50;
  }
</style>
