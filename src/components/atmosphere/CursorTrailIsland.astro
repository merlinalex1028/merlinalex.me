---
/**
 * CursorTrailIsland — desktop-only petal cursor trail.
 *
 * Spawns small petal elements following mouse movement.
 * Lightweight vanilla DOM + CSS animation (no tsParticles dependency).
 *
 * - Gated: off, reduced-motion, or mobile = disabled
 * - Throttled to 100ms between spawns
 * - Max 20 active trail particles
 * - Cleanup on View Transition navigation
 */
---

<div class="atmo-cursor-trail" transition:persist="atmo-cursor-trail"></div>

<style>
  @keyframes cursor-fall {
    0% {
      opacity: 1;
      transform: translateY(0) rotate(0deg);
    }
    100% {
      opacity: 0;
      transform: translateY(40px) rotate(180deg);
    }
  }

  .atmo-cursor-trail {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9999;
    overflow: hidden;
  }

  .cursor-petal {
    position: fixed;
    pointer-events: none;
    border-radius: 50% 0 50% 0;
    animation: cursor-fall 1s ease-out forwards;
    will-change: transform, opacity;
  }
</style>

<script>
  import {
    isOff,
    isReducedMotion,
    isMobile,
    onAtmoChange,
  } from '../../lib/atmosphere';

  const MAX_PARTICLES = 20;
  const SPAWN_THROTTLE_MS = 100;

  let activeParticles: HTMLSpanElement[] = [];
  let lastSpawnTime = 0;
  let mouseHandler: ((e: MouseEvent) => void) | null = null;
  let cleanupAtmo: (() => void) | null = null;
  let isActive = false;

  function randomBetween(min: number, max: number): number {
    return Math.random() * (max - min) + min;
  }

  function spawnPetal(x: number, y: number): void {
    const now = performance.now();
    if (now - lastSpawnTime < SPAWN_THROTTLE_MS) return;
    lastSpawnTime = now;

    // Enforce max particles
    if (activeParticles.length >= MAX_PARTICLES) {
      const oldest = activeParticles.shift();
      oldest?.remove();
    }

    const petal = document.createElement('span');
    petal.className = 'cursor-petal';

    const size = randomBetween(8, 12);
    const rotation = randomBetween(0, 360);
    const offsetX = randomBetween(-5, 5);
    const offsetY = randomBetween(-5, 5);

    // Use CSS variable for theme-linked color
    const accentColor = getComputedStyle(document.documentElement)
      .getPropertyValue('--color-accent')
      .trim();

    petal.style.cssText = [
      `left: ${x + offsetX}px`,
      `top: ${y + offsetY}px`,
      `width: ${size}px`,
      `height: ${size}px`,
      `background: ${accentColor || '#FFB7C5'}`,
      `transform: rotate(${rotation}deg)`,
    ].join('; ');

    document.body.appendChild(petal);
    activeParticles.push(petal);

    // Self-remove after animation
    petal.addEventListener(
      'animationend',
      () => {
        petal.remove();
        const idx = activeParticles.indexOf(petal);
        if (idx !== -1) activeParticles.splice(idx, 1);
      },
      { once: true }
    );
  }

  function attachListener(): void {
    if (mouseHandler) return;
    mouseHandler = (e: MouseEvent) => spawnPetal(e.clientX, e.clientY);
    document.addEventListener('mousemove', mouseHandler, { passive: true });
    isActive = true;
  }

  function detachListener(): void {
    if (mouseHandler) {
      document.removeEventListener('mousemove', mouseHandler);
      mouseHandler = null;
    }
    isActive = false;
  }

  function clearAllParticles(): void {
    for (const p of activeParticles) {
      p.remove();
    }
    activeParticles = [];
  }

  function activate(): void {
    if (isActive) return;
    attachListener();
  }

  function deactivate(): void {
    detachListener();
    clearAllParticles();
  }

  // Wait for window.__atmo__ to be available (race condition guard)
  function waitForAtmo(callback: () => void): void {
    if ((window as any).__atmo__) {
      callback();
    } else {
      const check = setInterval(() => {
        if ((window as any).__atmo__) {
          clearInterval(check);
          callback();
        }
      }, 50);
      setTimeout(() => clearInterval(check), 2000);
    }
  }

  // Initial gate (with atmo race-condition guard)
  waitForAtmo(() => {
    if (!isOff() && !isReducedMotion() && !isMobile()) {
      activate();
    }

    // Subscribe to intensity changes
    cleanupAtmo = onAtmoChange((state) => {
      if (state.level === 'off' || state.reducedMotion || isMobile()) {
        deactivate();
      } else {
        activate();
      }
    });
  });

  // Keep the island alive across View Transition navigation; only clear
  // transient particles so old trails don't float over the new page.
  document.addEventListener('astro:before-swap', () => {
    clearAllParticles();
  });
</script>
