---
// Live2D mascot island. Hidden unless /models/live2d-models.json configures models.
// Gated by intensity toggle (off = hidden).
---

<div class="atmo-live2d" id="l2d-root" transition:persist="atmo-live2d"></div>

<script>
  import { isOff, onAtmoChange } from '../../lib/atmosphere';

  interface Live2DConfig {
    models?: Array<{ path: string }>;
    tips?: {
      welcome?: string;
      touch?: string;
    };
  }

  const root = document.getElementById('l2d-root') as HTMLElement | null;
  let widgetLoaded = false;

  async function loadConfig(): Promise<Live2DConfig> {
    try {
      const res = await fetch('/models/live2d-models.json', {
        cache: 'no-store',
      });
      if (!res.ok) return {};

      const data = (await res.json()) as Live2DConfig;
      return data && typeof data === 'object' ? data : {};
    } catch {
      return {};
    }
  }

  function normalizeModels(config: Live2DConfig): Array<{ path: string }> {
    return (config.models ?? []).filter(
      (model) => model && typeof model.path === 'string' && model.path.length > 0
    );
  }

  if (root) {
    root.style.display = 'none';

    onAtmoChange((state) => {
      if (state.level === 'off' || !widgetLoaded) {
        root.style.display = 'none';
      }
    });

    async function loadLive2D(): Promise<void> {
      if (isOff()) return;

      const config = await loadConfig();
      const models = normalizeModels(config);
      if (models.length === 0) return;

      try {
        const { createWidget } = await import('l2d-widget');

        const widget = createWidget({
          model: models,
          tips: {
            welcome: config.tips?.welcome ?? '欢迎回来~',
            touch: config.tips?.touch ?? '别戳我啦~',
          },
        });

        widgetLoaded = true;
        root.style.display = '';

        // Subscribe to intensity changes for sleep/wake
        onAtmoChange((state) => {
          if (state.level === 'off' && widget?.sleep) {
            widget.sleep();
          }
        });
      } catch {
        root.style.display = 'none';
        console.warn('[Live2D] Failed to load configured model');
      }
    }

    // Load during idle time
    if ('requestIdleCallback' in window) {
      requestIdleCallback(loadLive2D, { timeout: 5000 });
    } else {
      setTimeout(loadLive2D, 2000);
    }
  }
</script>

<style>
  .atmo-live2d {
    position: fixed;
    bottom: 0;
    right: 20px;
    z-index: 100;
    width: 200px;
    height: 300px;
    pointer-events: auto;
    transition: opacity var(--duration-base, 300ms) var(--easing-default, ease);
  }

  /* Hide when intensity is off (CSS gate from global.css) */
  :global([data-atmo="off"]) .atmo-live2d {
    display: none !important;
  }
</style>
