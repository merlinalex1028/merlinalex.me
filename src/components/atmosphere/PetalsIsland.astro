---
/**
 * PetalsIsland — falling cherry blossom petals via tsParticles.
 *
 * - Renders inside AtmosphereLayer (position: fixed, pointer-events: none)
 * - Gated behind intensity toggle (off = hidden, reduced-motion = hidden)
 * - 30 petals desktop, 15 mobile (via responsive config)
 * - 30 FPS throttle, pauses on document.hidden
 * - Theme-linked colors: light pink in light mode, darker pink in dark mode
 */
---

<div class="atmo-petals" style="pointer-events: none; width: 100%; height: 100%;">
  <canvas id="tsparticles-petals"></canvas>
</div>

<script>
  import { isOff, isReducedMotion, onAtmoChange } from '../../lib/atmosphere';
  import type { Container } from '@tsparticles/engine';

  const CONTAINER_ID = 'tsparticles-petals';

  /** Light mode petal colors */
  const LIGHT_COLORS = ['#FFB7C5', '#FF69B4', '#FFC0CB'];
  /** Dark mode petal colors */
  const DARK_COLORS = ['#E84393', '#C0392B', '#FFB7C5'];

  let particlesContainer: Container | undefined;
  let initPromise: Promise<void> | null = null;

  function getThemeColors(): string[] {
    const theme =
      (window as Record<string, unknown>).__atmo__ &&
      typeof (window as Record<string, unknown>).__atmo__ === 'object'
        ? (
            (window as Record<string, unknown>).__atmo__ as Record<
              string,
              unknown
            >
          ).theme
        : 'light';
    return theme === 'dark' ? DARK_COLORS : LIGHT_COLORS;
  }

  async function initParticles(): Promise<void> {
    if (particlesContainer) return;
    if (initPromise) {
      await initPromise;
      return;
    }

    initPromise = (async () => {
      try {
        const { initParticlesEngine } = await import('@tsparticles/slim');
        const { loadSlim } = await import('@tsparticles/slim');
        const { loadImageShape } = await import(
          '@tsparticles/shape-image'
        );

        await initParticlesEngine(async (engine) => {
          await loadSlim(engine);
          await loadImageShape(engine);
        });

        const { tsParticles } = await import('@tsparticles/slim');

        particlesContainer = await tsParticles.load({
          id: CONTAINER_ID,
          options: {
            fullScreen: false,
            fpsLimit: 30,
            particles: {
              number: {
                value: 30,
                density: {
                  enable: true,
                  width: 1920,
                  height: 1080,
                },
              },
              color: {
                value: getThemeColors(),
              },
              shape: {
                type: 'image',
                image: {
                  src: '/petals/sakura.svg',
                  width: 32,
                  height: 32,
                },
              },
              opacity: {
                value: { min: 0.3, max: 0.8 },
                animation: {
                  enable: true,
                  speed: 0.5,
                  minimumValue: 0.1,
                },
              },
              size: {
                value: { min: 8, max: 16 },
                animation: {
                  enable: true,
                  speed: 2,
                  minimumValue: 4,
                },
              },
              move: {
                enable: true,
                direction: 'bottom-right',
                speed: { min: 1, max: 3 },
                straight: false,
                outModes: { default: 'out' },
                gravity: { enable: true, acceleration: 0.5 },
              },
              rotate: {
                value: { min: 0, max: 360 },
                animation: { enable: true, speed: 5 },
              },
              wobble: {
                enable: true,
                distance: 10,
                speed: 3,
              },
            },
            detectRetina: true,
            pauseOnBlur: true,
            responsive: [
              {
                maxWidth: 768,
                options: {
                  particles: {
                    number: { value: 15 },
                  },
                },
              },
            ],
          },
        });
      } catch (err) {
        console.warn('PetalsIsland: failed to init tsParticles', err);
      }
    })();

    await initPromise;
  }

  function destroyParticles(): void {
    if (particlesContainer) {
      particlesContainer.destroy();
      particlesContainer = undefined;
    }
    initPromise = null;
  }

  function hideContainer(): void {
    const el = document.querySelector('.atmo-petals') as HTMLElement | null;
    if (el) el.style.display = 'none';
  }

  function showContainer(): void {
    const el = document.querySelector('.atmo-petals') as HTMLElement | null;
    if (el) el.style.display = '';
  }

  // Initial gate: skip init if off or reduced motion
  if (!isOff() && !isReducedMotion()) {
    showContainer();
    void initParticles();
  } else {
    hideContainer();
  }

  // Subscribe to intensity changes
  onAtmoChange((state) => {
    if (state.level === 'off' || state.reducedMotion) {
      destroyParticles();
      hideContainer();
    } else {
      showContainer();
      void initParticles();
    }
  });
</script>
