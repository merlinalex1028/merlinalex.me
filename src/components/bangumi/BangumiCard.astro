---
interface Props {
  item: {
    subjectId: number;
    name: string;
    nameCn: string;
    cover: string;
    score: number;
    rate: number;
    type: number;
    epStatus: number;
    volStatus: number;
    eps: number;
    updatedAt?: string;
    comment?: string;
    tags: string[];
  };
}

const { item } = Astro.props;

const displayName = item.nameCn || item.name;
const statusLabel = item.type === 3 ? '在看' : item.type === 2 ? '看过' : item.type === 1 ? '想看' : '';
const progress = item.eps > 0 ? `${item.epStatus}/${item.eps} 集` : '';
---

<article class="bangumi-card" data-status={item.type === 3 ? 'doing' : item.type === 2 ? 'done' : 'wish'}>
  <div class="card-cover">
    {item.cover ? (
      <img
        src={item.cover}
        alt={displayName}
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="cover-placeholder" />
    )}
    {statusLabel && <span class={`status-tag status-${item.type}`}>{statusLabel}</span>}
  </div>
  <div class="card-body">
    <h3 class="card-title" title={displayName}>{displayName}</h3>
    <div class="card-meta">
      {item.score > 0 && (
        <span class="score" aria-label={`评分 ${item.score}`}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          {item.score.toFixed(1)}
        </span>
      )}
      {item.rate > 0 && (
        <span class="rate" aria-label={`个人评分 ${item.rate}`}>
          {item.rate}/10
        </span>
      )}
      {progress && <span class="progress">{progress}</span>}
    </div>
  </div>
</article>

<style>
  .bangumi-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 12px);
    overflow: hidden;
    transition: transform 150ms ease, box-shadow 150ms ease;
  }

  .bangumi-card:hover {
    transform: scale(1.02);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }

  .card-cover {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--color-surface-muted, #f0f0f0);
  }

  .card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cover-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-surface-muted, #f0f0f0);
  }

  .status-tag {
    position: absolute;
    top: 8px;
    right: 8px;
    padding: 2px 8px;
    border-radius: 9999px;
    font-size: 12px;
    font-weight: 600;
    color: #fff;
  }

  .status-3 {
    background: var(--color-accent, #ff6b9d);
  }

  .status-2 {
    background: var(--color-success, #4ade80);
  }

  .status-1 {
    background: var(--color-info, #60a5fa);
  }

  .card-body {
    padding: 12px;
  }

  .card-title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.4;
    margin: 0 0 8px;
    color: var(--color-fg);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    font-size: 12px;
    color: var(--color-fg-muted, #888);
  }

  .score {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    color: var(--color-accent, #ff6b9d);
    font-weight: 600;
  }

  .rate {
    color: var(--color-fg-muted, #888);
  }

  .progress {
    color: var(--color-fg-muted, #888);
  }
</style>
