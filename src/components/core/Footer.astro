---
import footerBg from '../../assets/footer.png';
import social from '../../data/social.json';

const quickLinks = [
  { label: '首页', href: '/' },
  { label: '文章', href: '/articles' },
  { label: '作品', href: '/works' },
  { label: '追更', href: '/bangumi' },
  { label: '友人', href: '/friends' },
  { label: '关于', href: '/about' },
  { label: '时间线', href: '/timeline' },
  { label: 'RSS', href: '/feed.xml' },
];

const contactLinks = [
  ...social.links,
  { name: 'RSS', url: '/feed.xml' },
];
---

<footer class="site-footer" style={`--footer-image: url(${footerBg.src})`}>
  <div class="footer-inner">
    <nav aria-label="快速导航">
      <h2>快速导航</h2>
      <ul>
        {quickLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
      </ul>
    </nav>
    <nav aria-label="链接我">
      <h2>链接我</h2>
      <ul>
        {
          contactLinks.map((link) => (
            <li>
              <a href={link.url} rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}>
                {link.name}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
  <p class="copyright">© 2026 MerlinAlex. All rights reserved.</p>
</footer>

<style>
  .site-footer {
    position: relative;
    color: #27367e;
    padding: clamp(4.25rem, 9vw, 6.5rem) 1rem 1.35rem;
    margin-top: 2.25rem;
    background:
      linear-gradient(180deg, rgba(236, 235, 251, 0) 0%, rgba(236, 235, 251, 0.35) 32%, rgba(236, 235, 251, 0.82) 100%),
      var(--footer-image) center bottom / cover no-repeat;
  }
  .footer-inner {
    max-width: 620px;
    margin: 0 auto 1.25rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(2rem, 6vw, 4.5rem);
    text-align: left;
  }
  .site-footer h2 {
    margin: 0 0 0.7rem;
    color: #102173;
    font-size: 1rem;
    font-weight: 900;
  }
  .site-footer ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .site-footer li {
    min-width: 4rem;
  }
  .site-footer a {
    color: #27367e;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 800;
    transition: color var(--duration-fast) var(--easing-default);
  }
  .site-footer a:hover,
  .site-footer a:focus-visible {
    color: var(--color-accent);
  }
  .copyright {
    margin: 0;
    color: #5d669c;
    text-align: center;
    font-size: 0.86rem;
    font-weight: 700;
  }

  @media (max-width: 560px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 1.25rem;
      max-width: 320px;
    }
  }
</style>
