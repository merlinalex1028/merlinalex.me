---
import { readFileSync } from 'node:fs';

// Parse the simple `id:` frontmatter from notice.md without gray-matter dep.
const raw = readFileSync('./src/data/notice.md', 'utf8');
const fmMatch = raw.match(/^---\s*\n([\s\S]*?)\n---\s*\n?([\s\S]*)$/);
let noticeId: string | undefined;
let noticeBody = '';
if (fmMatch) {
  const idLine = fmMatch[1].split('\n').find((l) => l.startsWith('id:'));
  if (idLine) noticeId = idLine.slice(3).trim().replace(/^["']|["']$/g, '');
  noticeBody = (fmMatch[2] || '').trim();
}
---

{
  noticeId && noticeBody && (
    <aside class="notice-bar" data-notice-id={noticeId} role="status">
      <span class="notice-body">{noticeBody}</span>
      <button type="button" class="notice-dismiss" aria-label="关闭公告">✕</button>
    </aside>

    <script is:inline define:vars={{ noticeId }}>
      (function () {
        var el = document.querySelector('.notice-bar');
        var btn = document.querySelector('.notice-dismiss');
        if (!el || !btn) return;
        try {
          if (localStorage.getItem('notice:dismissed:' + noticeId) === '1') {
            el.hidden = true;
            return;
          }
        } catch (e) { /* private mode */ }
        btn.addEventListener('click', function () {
          try { localStorage.setItem('notice:dismissed:' + noticeId, '1'); } catch (e) {}
          el.hidden = true;
        });
      })();
    </script>

    <style>
      .notice-bar {
        background: var(--color-surface);
        border-left: 3px solid var(--color-accent);
        color: var(--color-fg);
        padding: 0.5rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.9rem;
      }
      .notice-body {
        flex: 1;
      }
      .notice-dismiss {
        background: transparent;
        border: 0;
        color: var(--color-fg-muted);
        cursor: pointer;
        font-size: 1rem;
        padding: 0 0.25rem;
      }
      .notice-dismiss:hover,
      .notice-dismiss:focus-visible {
        color: var(--color-fg);
      }
    </style>
  )
}
