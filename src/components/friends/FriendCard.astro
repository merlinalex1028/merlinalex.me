---
interface Props {
  name: string;
  url: string;
  avatar?: string;
  description?: string;
}

const { name, url, avatar, description } = Astro.props;
const initial = name.charAt(0);
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="friend-card"
>
  <div class="friend-avatar">
    {avatar ? (
      <img
        src={avatar}
        alt={name}
        width="48"
        height="48"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <span class="avatar-fallback">{initial}</span>
    )}
  </div>
  <div class="friend-info">
    <h3 class="friend-name">{name}</h3>
    {description && <p class="friend-desc">{description}</p>}
  </div>
</a>

<style>
  .friend-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    text-decoration: none;
    color: inherit;
    position: relative;
    transition:
      border-color var(--duration-fast, 150ms) var(--easing-default, ease),
      box-shadow var(--duration-base, 250ms) var(--easing-default, ease);
  }

  .friend-card:hover,
  .friend-card:focus-visible {
    border-color: var(--color-accent);
    box-shadow: 0 4px 16px rgba(255, 107, 157, 0.12);
  }

  .friend-avatar {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-accent-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .friend-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .avatar-fallback {
    font-size: 20px;
    font-weight: 600;
    color: var(--color-accent);
    line-height: 1;
  }

  .friend-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .friend-name {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-fg);
    margin: 0;
    line-height: 1.4;
  }

  .friend-desc {
    font-size: 14px;
    color: var(--color-fg-muted);
    margin: 0;
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
