---
import persona from '../../data/persona.yaml';
import heroImage from '../../assets/hero.png';
---

<section class="hero" style={`--hero-image: url(${heroImage.src})`}>
  <div class="sr-only">
    <h1>MerlinAlex</h1>
    <p>{persona.tagline}</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    max-width: none;
    aspect-ratio: 1671 / 941;
    margin: 0 auto;
    overflow: hidden;
    border: 0;
    border-radius: 0;
    background: var(--hero-image) center / cover no-repeat;
  }
  .hero::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 18%;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(236, 235, 251, 0) 0%, #ecebfb 100%);
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 720px) {
    .hero {
      margin-top: 0;
      min-height: 0;
      aspect-ratio: 1671 / 941;
      border-radius: 0;
      background-position: center;
    }
  }
</style>
