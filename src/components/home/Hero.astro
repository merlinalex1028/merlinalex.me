---
import persona from '../../data/persona.yaml';
---

<section class="hero">
  <h1 class="hero-name">{persona.name.zh}</h1>
  <p class="hero-tagline">{persona.tagline}</p>
  <a class="cta" href="/about">进入次元</a>
</section>

<style>
  .hero {
    text-align: center;
    padding: var(--space-2xl, 3rem) 1rem var(--space-xl, 2rem);
    max-width: 768px;
    margin: 0 auto;
  }
  .hero-name {
    font-size: 32px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 600;
    color: var(--color-fg);
    margin: 0 0 0.75rem 0;
  }
  .hero-tagline {
    font-size: 16px;
    line-height: 1.5;
    color: var(--color-fg-muted);
    font-style: italic;
    margin: 0 auto 1.5rem auto;
    max-width: 32em;
  }
  .hero .cta {
    display: inline-block;
    background: var(--color-accent);
    color: white;
    padding: 12px 32px;
    border-radius: var(--radius-md, 12px);
    min-height: 56px;
    line-height: 32px;
    font-weight: 600;
    text-decoration: none;
    transition: background-color var(--duration-fast, 150ms) var(--easing-default, ease);
  }
  .hero .cta:hover,
  .hero .cta:focus-visible {
    background: var(--color-accent-hover);
  }
</style>
