---
import homePost from '../../assets/home-post.png';
import { calculateReadingTime } from '../../utils/reading-time';

const { articles = [] } = Astro.props;
const article = articles[0];
const readingMinutes = article ? calculateReadingTime(article.body ?? '') : 1;
---

<section class="latest-articles">
  <header class="section-head">
    <div>
      <h2>最新文章</h2>
      <p>记录灵感、思考和热爱吧</p>
    </div>
    <a href="/articles">查看更多</a>
  </header>
  {!article ? (
    <div class="empty-state">
      <h3>还没有文章</h3>
      <p>撰写第一篇之后会出现在这里</p>
      <a class="cta" href="/articles">撰写第一篇</a>
    </div>
  ) : (
    <article class="article-feature">
      <a class="article-image" href={`/articles/${article.id}`} aria-label={article.data.title}>
        <img src={homePost.src} alt="" loading="lazy" decoding="async" />
      </a>
      <div class="article-copy">
        <h3>
          <a href={`/articles/${article.id}`}>{article.data.title}</a>
        </h3>
        {article.data.description && <p class="excerpt">{article.data.description}</p>}
        {article.data.tags?.length > 0 && (
          <ul class="tag-list" aria-label="文章标签">
            {article.data.tags.slice(0, 3).map((tag: string) => <li>{tag}</li>)}
          </ul>
        )}
        <div class="article-meta">
          <time datetime={article.data.publishedAt.toISOString()}>
            {article.data.publishedAt.toLocaleDateString('zh-CN')}
          </time>
          <span>{readingMinutes} 分钟阅读</span>
        </div>
      </div>
    </article>
  )}
</section>

<style>
  .latest-articles {
    max-width: min(1260px, calc(100% - 112px));
    margin: 1.15rem auto 0;
    padding: clamp(1rem, 2vw, 1.35rem);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.74);
    box-shadow:
      0 16px 34px rgba(100, 83, 204, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(16px) saturate(140%);
    -webkit-backdrop-filter: blur(16px) saturate(140%);
  }
  .section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .latest-articles h2 {
    font-size: clamp(1.55rem, 3vw, 2rem);
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: 0;
    color: #102173;
    margin: 0;
  }
  .section-head p {
    margin: 0.35rem 0 0;
    color: #53609a;
    font-size: 0.95rem;
    font-weight: 700;
  }
  .section-head a {
    flex: 0 0 auto;
    color: var(--color-accent);
    font-weight: 800;
    text-decoration: none;
  }
  .section-head a::after {
    content: " ->";
  }
  .empty-state {
    border-radius: 16px;
    padding: var(--space-2xl, 3rem) var(--space-md, 1rem);
    text-align: center;
    background: rgba(255, 255, 255, 0.36);
  }
  .empty-state h3 {
    font-size: 20px;
    font-weight: 600;
    color: var(--color-fg);
    margin: 0 0 0.5rem 0;
  }
  .empty-state p {
    color: var(--color-fg-muted);
    margin: 0 0 1.25rem 0;
  }
  .empty-state .cta {
    display: inline-block;
    background: var(--color-accent);
    color: white;
    padding: 8px 20px;
    border-radius: var(--radius-md, 12px);
    text-decoration: none;
    font-weight: 600;
    transition: background-color var(--duration-fast, 150ms) var(--easing-default, ease);
  }
  .empty-state .cta:hover,
  .empty-state .cta:focus-visible {
    background: var(--color-accent-hover);
  }
  .article-feature {
    display: grid;
    grid-template-columns: minmax(260px, 0.88fr) minmax(280px, 1.5fr);
    gap: clamp(1.25rem, 3vw, 2rem);
    align-items: center;
    padding: 0;
  }
  .article-image {
    display: block;
    aspect-ratio: 2.06 / 1;
    overflow: hidden;
    border-radius: 14px;
    background: var(--color-surface-muted);
    box-shadow: 0 12px 24px rgba(35, 45, 128, 0.12);
  }
  .article-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--easing-default);
  }
  .article-feature:hover .article-image img {
    transform: scale(1.035);
  }
  .article-copy h3 {
    margin: 0 0 0.8rem;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.25;
    font-weight: 900;
  }
  .article-copy h3 a {
    color: #12237a;
    text-decoration: none;
  }
  .article-copy h3 a:hover,
  .article-copy h3 a:focus-visible {
    color: var(--color-accent);
  }
  .excerpt {
    max-width: 42em;
    font-size: 1rem;
    line-height: 1.75;
    color: #445393;
    margin: 0 0 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
  }
  .tag-list li {
    padding: 0.28rem 0.65rem;
    border-radius: 999px;
    background: rgba(117, 84, 246, 0.12);
    color: var(--color-accent);
    font-size: 0.78rem;
    font-weight: 800;
  }
  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.4rem;
    color: #27367e;
    font-size: 0.92rem;
    font-weight: 800;
  }

  @media (max-width: 760px) {
    .latest-articles {
      max-width: calc(100% - 2rem);
    }
    .section-head {
      align-items: flex-end;
    }
    .article-feature {
      grid-template-columns: 1fr;
    }
  }
</style>
