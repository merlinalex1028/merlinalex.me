---
const { articles = [] } = Astro.props;
---

<section class="latest-articles">
  <h2>最新文章</h2>
  {articles.length === 0 ? (
    <div class="empty-state">
      <h3>还没有文章</h3>
      <p>撰写第一篇之后会出现在这里 ✨</p>
      <a class="cta" href="/articles">撰写第一篇</a>
    </div>
  ) : (
    <ul class="article-grid">
      {articles.map((article: any) => (
        <li class="article-card">
          <a href={`/articles/${article.id}`}>
            <h3>{article.data.title}</h3>
            {article.data.description && <p class="excerpt">{article.data.description}</p>}
            <time datetime={article.data.publishedAt.toISOString()}>
              {article.data.publishedAt.toLocaleDateString('zh-CN')}
            </time>
          </a>
        </li>
      ))}
    </ul>
  )}
</section>

<style>
  .latest-articles {
    max-width: 768px;
    margin: 0 auto;
    padding: var(--space-xl, 2rem) 1rem;
  }
  .latest-articles h2 {
    font-size: 24px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-fg);
    margin: 0 0 var(--space-md, 1rem) 0;
  }
  .empty-state {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg, 20px);
    padding: var(--space-2xl, 3rem) var(--space-md, 1rem);
    text-align: center;
  }
  .empty-state h3 {
    font-size: 20px;
    font-weight: 600;
    color: var(--color-fg);
    margin: 0 0 0.5rem 0;
  }
  .empty-state p {
    color: var(--color-fg-muted);
    margin: 0 0 1.25rem 0;
  }
  .empty-state .cta {
    display: inline-block;
    background: var(--color-accent);
    color: white;
    padding: 8px 20px;
    border-radius: var(--radius-md, 12px);
    text-decoration: none;
    font-weight: 600;
    transition: background-color var(--duration-fast, 150ms) var(--easing-default, ease);
  }
  .empty-state .cta:hover,
  .empty-state .cta:focus-visible {
    background: var(--color-accent-hover);
  }
  .article-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md, 1rem);
  }
  @media (min-width: 640px) {
    .article-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .article-card a {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg, 20px);
    padding: var(--space-md, 1rem);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--duration-fast, 150ms) var(--easing-default, ease),
                box-shadow var(--duration-base, 250ms) var(--easing-default, ease);
  }
  .article-card a:hover,
  .article-card a:focus-visible {
    border-color: var(--color-accent);
    box-shadow: 0 4px 16px rgba(255, 107, 157, 0.12);
  }
  .article-card h3 {
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-fg);
    margin: 0 0 0.5rem 0;
  }
  .article-card .excerpt {
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-fg-muted);
    margin: 0 0 0.75rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .article-card time {
    font-size: 12px;
    color: var(--color-fg-muted);
  }
</style>
