---
const { articleCount = 0, totalWords = 0 } = Astro.props;

// Runtime: days since launch date
const LAUNCH_DATE = new Date('2026-06-01');
const runtimeDays = Math.floor(
  (Date.now() - LAUNCH_DATE.getTime()) / (1000 * 60 * 60 * 24)
);
---

<section class="site-stats">
  <div class="stat">
    <div class="stat-label">运行时间</div>
    <div class="stat-value"><span>{runtimeDays}</span> 天</div>
  </div>
  <div class="stat">
    <div class="stat-label">文章数</div>
    <div class="stat-value"><span>{articleCount}</span> 篇</div>
  </div>
  <div class="stat">
    <div class="stat-label">总字数</div>
    <div class="stat-value"><span>{totalWords.toLocaleString()}</span> 字</div>
  </div>
  <div class="stat">
    <div class="stat-label">访客数</div>
    <div class="stat-value">
      <span id="busuanzi_value_site_uv">...</span> 人
    </div>
  </div>
</section>

<script async src="https://busuanzi.icodeq.com/busuanzi.pure.mini.js"></script>

<style>
  .site-stats {
    max-width: 768px;
    margin: 0 auto;
    padding: var(--space-md, 1rem) 1rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-sm, 0.5rem);
  }
  .stat {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 12px);
    padding: var(--space-md, 1rem) var(--space-sm, 0.5rem);
    text-align: center;
  }
  .stat-label {
    font-size: 12px;
    color: var(--color-fg-muted);
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
  }
  .stat-value {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-fg);
  }
  .stat-value span {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .site-stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
