---
const { articleCount = 0, totalWords = 0 } = Astro.props;
---

<section class="site-stats">
  <div class="stat">
    <div class="stat-label">运行时间</div>
    <div class="stat-value">即将上线</div>
  </div>
  <div class="stat">
    <div class="stat-label">文章数</div>
    <div class="stat-value"><span>{articleCount}</span> 篇</div>
  </div>
  <div class="stat">
    <div class="stat-label">总字数</div>
    <div class="stat-value"><span>{totalWords}</span> 字</div>
  </div>
</section>

<style>
  .site-stats {
    max-width: 768px;
    margin: 0 auto;
    padding: var(--space-md, 1rem) 1rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm, 0.5rem);
  }
  .stat {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 12px);
    padding: var(--space-md, 1rem) var(--space-sm, 0.5rem);
    text-align: center;
  }
  .stat-label {
    font-size: 12px;
    color: var(--color-fg-muted);
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
  }
  .stat-value {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-fg);
  }
  .stat-value span {
    color: var(--color-accent);
  }
</style>
