---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'microblog'>;
  isArchived?: boolean;
}

const { post, isArchived = false } = Astro.props;

const { publishedAt, content, mood, tags = [], images = [] } = post.data;

const dateStr = publishedAt.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

const visibleImages = images.slice(0, 3);
const overflowCount = images.length - 3;
---

<article class:list={['microblog-card', { archived: isArchived }]}>
  <header class="card-header">
    <time datetime={publishedAt.toISOString()}>{dateStr}</time>
    {mood && <span class="mood-badge" aria-label={`心情: ${mood}`}>{mood}</span>}
    {isArchived && <span class="archive-badge">归档</span>}
  </header>

  <p class="card-content">{content}</p>

  {visibleImages.length > 0 && (
    <div class="card-images">
      {visibleImages.map((src: string) => (
        <img
          src={src}
          alt=""
          loading="lazy"
          decoding="async"
          data-zoom
        />
      ))}
      {overflowCount > 0 && (
        <span class="image-overflow">+{overflowCount}</span>
      )}
    </div>
  )}

  {tags.length > 0 && (
    <footer class="card-tags">
      {tags.map((tag: string) => (
        <span class="tag-chip">{tag}</span>
      ))}
    </footer>
  )}
</article>

<style>
  .microblog-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 12px);
    padding: var(--space-md, 1rem);
    transition:
      opacity var(--duration-base, 250ms) var(--easing-default, ease),
      box-shadow var(--duration-base, 250ms) var(--easing-default, ease);
  }

  .microblog-card:hover {
    box-shadow: 0 2px 12px rgba(255, 107, 157, 0.1);
  }

  .microblog-card.archived {
    opacity: 0.7;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .card-header time {
    font-size: 12px;
    color: var(--color-fg-muted);
  }

  .mood-badge {
    font-size: 16px;
    line-height: 1;
  }

  .archive-badge {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 9999px;
    background: var(--color-surface-muted);
    color: var(--color-fg-muted);
    border: 1px solid var(--color-border);
    font-weight: 500;
  }

  .card-content {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-fg);
    margin: 0 0 0.75rem 0;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .card-images {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    overflow: hidden;
    border-radius: var(--radius-sm, 8px);
  }

  .card-images img {
    width: 0;
    flex: 1;
    max-width: 33.33%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: var(--radius-sm, 8px);
    cursor: zoom-in;
    transition: transform var(--duration-fast, 150ms) var(--easing-default, ease);
  }

  .card-images img:hover {
    transform: scale(1.02);
  }

  .image-overflow {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 60px;
    aspect-ratio: 1;
    background: var(--color-surface-muted);
    border-radius: var(--radius-sm, 8px);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-fg-muted);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag-chip {
    font-size: 12px;
    padding: 2px 10px;
    border-radius: 9999px;
    background: var(--color-accent-subtle);
    color: var(--color-accent);
    font-weight: 500;
  }
</style>
