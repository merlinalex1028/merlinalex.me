---
import PagefindConfig from 'astro-pagefind/components/PagefindConfig.astro';
---

<div class="search-wrapper">
  <PagefindConfig />
  <pagefind-searchbox
    placeholder="搜索文章..."
    shortcut="/"
    max-results="10"
  />
</div>

<style>
  .search-wrapper {
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--color-fg);
    --pagefind-ui-background: var(--color-surface);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-font: inherit;
    position: relative;
  }

  :global(pagefind-searchbox) {
    --pagefind-ui-scale: 0.85;
    font-family: inherit;
  }

  :global(.pagefind-ui) {
    font-family: inherit;
  }

  :global(.pagefind-ui form) {
    position: relative;
  }

  :global(.pagefind-ui input) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 8px);
    color: var(--color-fg);
    font-size: 0.875rem;
    padding: 0.375rem 0.75rem;
    width: 180px;
    transition: width var(--duration-fast, 0.15s) var(--easing-default, ease),
      border-color var(--duration-fast, 0.15s) var(--easing-default, ease);
  }

  :global(.pagefind-ui input:focus) {
    width: 260px;
    border-color: var(--color-accent);
    outline: none;
  }

  :global(.pagefind-ui .pagefind-ui__results) {
    position: absolute;
    top: 100%;
    right: 0;
    width: 380px;
    max-height: 400px;
    overflow-y: auto;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 8px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    z-index: 100;
    margin-top: 0.5rem;
    padding: 0.5rem;
  }

  :global(.pagefind-ui .pagefind-ui__result) {
    padding: 0.75rem;
    border-radius: var(--radius-sm, 6px);
    transition: background var(--duration-fast, 0.15s) var(--easing-default, ease);
  }

  :global(.pagefind-ui .pagefind-ui__result:hover) {
    background: var(--color-surface);
  }

  :global(.pagefind-ui .pagefind-ui__result-title) {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-fg);
    margin-bottom: 0.25rem;
  }

  :global(.pagefind-ui .pagefind-ui__result-excerpt) {
    font-size: 0.8rem;
    color: var(--color-fg-muted);
    line-height: 1.5;
  }

  :global(.pagefind-ui mark) {
    background: color-mix(in srgb, var(--color-accent) 25%, transparent);
    color: var(--color-accent);
    padding: 0 2px;
    border-radius: 2px;
  }

  :global(.pagefind-ui .pagefind-ui__message) {
    font-size: 0.8rem;
    color: var(--color-fg-muted);
    padding: 0.5rem 0.75rem;
  }

  @media (max-width: 640px) {
    :global(.pagefind-ui input) {
      width: 120px;
      font-size: 0.8rem;
    }

    :global(.pagefind-ui input:focus) {
      width: 200px;
    }

    :global(.pagefind-ui .pagefind-ui__results) {
      width: calc(100vw - 2rem);
      right: -0.5rem;
    }
  }
</style>
