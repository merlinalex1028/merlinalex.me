---
// CreationLightbox — client-side lightbox overlay for creations gallery.
// Uses client:idle directive for deferred loading.
---

<div class="lightbox-overlay" id="creation-lightbox" role="dialog" aria-modal="true" aria-label="作品预览">
  <button class="lightbox-close" aria-label="关闭">&times;</button>
  <button class="lightbox-prev" aria-label="上一张">&lsaquo;</button>
  <button class="lightbox-next" aria-label="下一张">&rsaquo;</button>
  <div class="lightbox-content">
    <img class="lightbox-image" src="" alt="" />
    <div class="lightbox-info">
      <h3 class="lightbox-title"></h3>
      <p class="lightbox-description"></p>
      <span class="lightbox-counter"></span>
    </div>
  </div>
</div>

<script>
  interface LightboxState {
    images: string[];
    title: string;
    description: string;
    currentIndex: number;
    isOpen: boolean;
  }

  const state: LightboxState = {
    images: [],
    title: '',
    description: '',
    currentIndex: 0,
    isOpen: false,
  };

  let overlay: HTMLElement | null = null;
  let imgEl: HTMLImageElement | null = null;
  let titleEl: HTMLElement | null = null;
  let descEl: HTMLElement | null = null;
  let counterEl: HTMLElement | null = null;
  let prevBtn: HTMLElement | null = null;
  let nextBtn: HTMLElement | null = null;

  function cacheDom() {
    overlay = document.getElementById('creation-lightbox');
    imgEl = overlay?.querySelector('.lightbox-image') as HTMLImageElement | null;
    titleEl = overlay?.querySelector('.lightbox-title') ?? null;
    descEl = overlay?.querySelector('.lightbox-description') ?? null;
    counterEl = overlay?.querySelector('.lightbox-counter') ?? null;
    prevBtn = overlay?.querySelector('.lightbox-prev') ?? null;
    nextBtn = overlay?.querySelector('.lightbox-next') ?? null;
  }

  function updateDisplay() {
    if (!overlay || !imgEl || !titleEl || !descEl || !counterEl || !prevBtn || !nextBtn) return;

    const current = state.images[state.currentIndex];
    if (!current) return;

    imgEl.src = current;
    imgEl.alt = `${state.title} — ${state.currentIndex + 1}`;
    titleEl.textContent = state.title;
    descEl.textContent = state.description;

    const total = state.images.length;
    counterEl.textContent = total > 1 ? `${state.currentIndex + 1} / ${total}` : '';

    prevBtn.style.display = total > 1 ? 'flex' : 'none';
    nextBtn.style.display = total > 1 ? 'flex' : 'none';
  }

  function openLightbox(images: string[], title: string, description: string, startIndex: number) {
    state.images = images;
    state.title = title;
    state.description = description;
    state.currentIndex = startIndex;
    state.isOpen = true;

    updateDisplay();
    overlay?.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    state.isOpen = false;
    overlay?.classList.remove('active');
    document.body.style.overflow = '';
  }

  function goToPrev() {
    if (state.images.length <= 1) return;
    state.currentIndex = (state.currentIndex - 1 + state.images.length) % state.images.length;
    updateDisplay();
  }

  function goToNext() {
    if (state.images.length <= 1) return;
    state.currentIndex = (state.currentIndex + 1) % state.images.length;
    updateDisplay();
  }

  function handleCardClick(e: Event) {
    const card = (e.target as HTMLElement).closest('.creation-card');
    if (!card) return;

    const imagesRaw = card.getAttribute('data-images');
    const title = card.getAttribute('data-title') || '';
    const description = card.getAttribute('data-description') || '';

    if (!imagesRaw) return;

    try {
      const images = JSON.parse(imagesRaw) as string[];
      if (images.length === 0) return;
      openLightbox(images, title, description, 0);
    } catch {
      // Invalid JSON in data-images — ignore
    }
  }

  function handleKeydown(e: KeyboardEvent) {
    if (!state.isOpen) return;

    switch (e.key) {
      case 'Escape':
        closeLightbox();
        break;
      case 'ArrowLeft':
        goToPrev();
        break;
      case 'ArrowRight':
        goToNext();
        break;
    }
  }

  function handleOverlayClick(e: Event) {
    if (e.target === overlay) {
      closeLightbox();
    }
  }

  function init() {
    cacheDom();
    if (!overlay) return;

    document.addEventListener('click', handleCardClick);
    overlay.addEventListener('click', handleOverlayClick);
    document.addEventListener('keydown', handleKeydown);

    overlay.querySelector('.lightbox-close')?.addEventListener('click', closeLightbox);
    prevBtn?.addEventListener('click', goToPrev);
    nextBtn?.addEventListener('click', goToNext);
  }

  init();
  document.addEventListener('astro:after-swap', () => {
    init();
  });
</script>

<style>
  .lightbox-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.9);
    opacity: 0;
    transition: opacity 200ms var(--easing-default, ease);
  }

  .lightbox-overlay.active {
    display: flex;
    opacity: 1;
  }

  .lightbox-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 90vw;
    max-height: 90vh;
  }

  .lightbox-image {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 8px;
  }

  .lightbox-info {
    text-align: center;
    padding: 1rem;
    color: white;
    max-width: 600px;
  }

  .lightbox-title {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 0.25rem 0;
  }

  .lightbox-description {
    font-size: 14px;
    opacity: 0.8;
    margin: 0 0 0.5rem 0;
  }

  .lightbox-counter {
    font-size: 13px;
    opacity: 0.6;
  }

  .lightbox-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: rgba(255, 255, 255, 0.1);
    color: white;
    border: none;
    cursor: pointer;
    border-radius: 50%;
    width: 48px;
    height: 48px;
    font-size: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 150ms ease;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .lightbox-prev,
  .lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.1);
    color: white;
    border: none;
    cursor: pointer;
    border-radius: 50%;
    width: 48px;
    height: 48px;
    font-size: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 150ms ease;
  }

  .lightbox-prev {
    left: 16px;
  }

  .lightbox-next {
    right: 16px;
  }

  .lightbox-prev:hover,
  .lightbox-next:hover {
    background: rgba(255, 255, 255, 0.2);
  }
</style>
