---
import { Icon } from 'astro-icon/components';

interface Props {
  name: string;
  description?: string;
  url: string;
  github?: string;
  tags: string[];
  cover?: string;
  stars?: number;
}

const { name, description, url, github, tags, cover, stars } = Astro.props;
---

<article class="project-card">
  {cover && (
    <div class="project-cover">
      <img
        src={cover}
        alt={name}
        width="400"
        height="200"
        loading="lazy"
      />
    </div>
  )}
  <div class="project-body">
    <h3 class="project-name">
      <a href={url} target="_blank" rel="noopener noreferrer">{name}</a>
    </h3>
    {description && <p class="project-desc">{description}</p>}
    {tags.length > 0 && (
      <div class="project-tags">
        {tags.map(tag => (
          <span class="tag-chip">{tag}</span>
        ))}
      </div>
    )}
    {github && (
      <a
        href={github}
        class="github-badge"
        target="_blank"
        rel="noopener noreferrer"
      >
        <Icon name="mdi:github" />
        <span>{stars !== undefined ? stars.toLocaleString() : '—'}</span>
      </a>
    )}
  </div>
</article>

<style>
  .project-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    overflow: hidden;
    transition:
      border-color var(--duration-fast, 150ms) var(--easing-default, ease),
      box-shadow var(--duration-base, 250ms) var(--easing-default, ease);
  }

  .project-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 16px rgba(255, 107, 157, 0.12);
  }

  .project-cover img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }

  .project-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .project-name {
    font-size: 16px;
    font-weight: 600;
    margin: 0;
  }

  .project-name a {
    color: var(--color-fg);
    text-decoration: none;
    transition: color var(--duration-fast, 150ms) var(--easing-default, ease);
  }

  .project-name a:hover {
    color: var(--color-accent);
  }

  .project-desc {
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-fg-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag-chip {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 9999px;
    font-size: 13px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-fg-muted);
  }

  .github-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    color: var(--color-fg-muted);
    text-decoration: none;
    transition: color var(--duration-fast, 150ms) var(--easing-default, ease);
  }

  .github-badge:hover {
    color: var(--color-fg);
  }

  .github-badge svg {
    width: 16px;
    height: 16px;
  }
</style>
