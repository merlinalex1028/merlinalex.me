---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleTOC from '../../components/articles/ArticleTOC.astro';
import CopyCodeButton from '../../components/articles/CopyCodeButton.astro';
import ImageLightbox from '../../components/articles/ImageLightbox.astro';
import ArticleNav from '../../components/articles/ArticleNav.astro';
import RelatedPosts from '../../components/articles/RelatedPosts.astro';
import ShareButtons from '../../components/articles/ShareButtons.astro';
import CopyrightFooter from '../../components/articles/CopyrightFooter.astro';
import TopButton from '../../components/articles/TopButton.astro';
import ReadingMeta from '../../components/articles/ReadingMeta.astro';
import { calculateReadingTime } from '../../utils/reading-time';
import { findRelated } from '../../utils/related-posts';

export async function getStaticPaths() {
  const articles = await getCollection(
    'articles',
    ({ data }) => !data.draft
  );

  return articles.map(article => ({
    params: { id: article.id },
    props: { article, allArticles: articles },
  }));
}

const { article, allArticles } = Astro.props;
const { Content, headings } = await render(article);

const readingMinutes = calculateReadingTime(article.body ?? '');
const related = findRelated(article, allArticles, 3);

// Find prev/next by publishedAt
const sorted = [...allArticles]
  .filter(a => !a.data.draft)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const currentIndex = sorted.findIndex(a => a.id === article.id);
const prev = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : undefined;
const next = currentIndex > 0 ? sorted[currentIndex - 1] : undefined;

const permalink = new URL(`/articles/${article.id}/`, Astro.site).toString();
---

<BaseLayout
  title={article.data.title}
  description={article.data.description}
  type="article"
>
  <div class="article-layout">
    {article.data.toc && (
      <ArticleTOC headings={headings} />
    )}

    <article class="article-body">
      <header class="article-header">
        <h1>{article.data.title}</h1>
        <ReadingMeta minutes={readingMinutes} updatedAt={article.data.updatedAt} />
        {article.data.cover && (
          <img
            src={article.data.cover}
            alt={`${article.data.title} 封面图`}
            class="cover-image"
          />
        )}
      </header>

      <div class="prose">
        <Content />
      </div>

      <ShareButtons title={article.data.title} url={permalink} />
      <CopyrightFooter title={article.data.title} url={permalink} />
      <ArticleNav prev={prev} next={next} />
      <RelatedPosts articles={related} />
    </article>
  </div>

  <TopButton />
  <CopyCodeButton />
  <ImageLightbox />
</BaseLayout>

<style>
  .article-layout {
    max-width: 1024px;
    margin: 0 auto;
    padding: 0 1rem 2rem;
    display: flex;
    gap: 2rem;
  }

  @media (min-width: 1024px) {
    .article-layout {
      padding: 0 2rem 2rem;
    }
  }

  .article-body {
    flex: 1;
    min-width: 0;
    max-width: 768px;
  }

  .article-header {
    margin-bottom: 2rem;
  }

  .article-header h1 {
    font-size: 28px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-fg);
    margin: 0;
  }

  .cover-image {
    width: 100%;
    border-radius: 12px;
    margin-top: 1.5rem;
    object-fit: cover;
  }

  /* Prose styling */
  .prose {
    font-size: 16px;
    line-height: 1.5;
    color: var(--color-fg);
  }

  .prose :global(h2) {
    font-size: 24px;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-fg);
  }

  .prose :global(h3) {
    font-size: 16px;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-fg);
  }

  .prose :global(p) {
    margin: 0 0 1rem 0;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .prose :global(a:hover) {
    text-decoration: underline;
  }

  .prose :global(code) {
    background: var(--color-surface);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 14px;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }

  .prose :global(pre) {
    border-radius: 12px;
    overflow: hidden;
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    font-size: 14px;
    line-height: 1.6;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent-subtle);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-fg-muted);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1rem 0;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.25rem;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 14px;
  }

  .prose :global(th),
  .prose :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .prose :global(th) {
    background: var(--color-surface);
    font-weight: 600;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }
</style>
