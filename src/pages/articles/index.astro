---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagChips from '../../components/articles/TagChips.astro';
import ArticleListItem from '../../components/articles/ArticleListItem.astro';
import { calculateReadingTime } from '../../utils/reading-time';
import { extractTags } from '../../utils/tag-extraction';
import { countWords } from '../../utils/word-count';
import articlesHero from '../../assets/articles/articles-hero.svg';
import featuredArticle from '../../assets/articles/featured-article.png';
import catCorner from '../../assets/articles/cat-corner.png';

const allArticles = await getCollection(
  'articles',
  ({ data }) => !data.draft
);

const tags = extractTags(allArticles);
const selectedTag = Astro.url.searchParams.get('tag');
const tagCounts = Object.fromEntries(
  tags.map(tag => [
    tag,
    allArticles.filter(article => article.data.tags.includes(tag)).length,
  ])
);

const sorted = [...allArticles].sort((a, b) => {
  if (a.data.sticky !== b.data.sticky) return a.data.sticky ? -1 : 1;
  const timeDiff = b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
  if (timeDiff !== 0) return timeDiff;
  return a.id.localeCompare(b.id);
});

const filtered = selectedTag
  ? sorted.filter(a => a.data.tags.includes(selectedTag))
  : sorted;

const featured = filtered.find(article => article.data.sticky) ?? filtered[0];
const regularArticles = featured
  ? filtered.filter(article => article.id !== featured.id)
  : filtered;

const totalWords = allArticles.reduce((sum, article) => sum + countWords(article.body ?? ''), 0);
const categories = new Set(allArticles.map(article => article.data.category).filter(Boolean));
const latestUpdated = [...allArticles]
  .sort((a, b) => {
    const aTime = (a.data.updatedAt ?? a.data.publishedAt).getTime();
    const bTime = (b.data.updatedAt ?? b.data.publishedAt).getTime();
    return bTime - aTime;
  })[0];
const latestDate = latestUpdated
  ? (latestUpdated.data.updatedAt ?? latestUpdated.data.publishedAt).toLocaleDateString('zh-CN')
  : '暂无';

const formatWords = (words: number) => {
  if (words >= 10000) return `${(words / 10000).toFixed(1)}w`;
  if (words >= 1000) return `${(words / 1000).toFixed(1)}k`;
  return `${words}`;
};
---

<BaseLayout title="文章" description="全部文章 — merlinalex.me" type="website">
  <section class="articles-page">
    <header class="articles-hero">
      <div class="hero-copy">
        <p class="hero-kicker">Articles</p>
        <h1>文章小屋</h1>
        <p>
          记录前端开发、个人灵感、站点搭建与一些可爱的技术想法。
        </p>
      </div>
      <img
        class="hero-image"
        src={articlesHero.src}
        width={articlesHero.width}
        height={articlesHero.height}
        alt=""
        loading="eager"
        decoding="async"
      />
    </header>

    <TagChips tags={tags} selected={selectedTag} counts={tagCounts} total={allArticles.length} />

    <div class="articles-content">
      <div class="articles-main">
        {featured && (
          <section class="featured-section" aria-labelledby="featured-heading">
            <h2 id="featured-heading" class="section-heading">置顶文章</h2>
            <a href={`/articles/${featured.id}`} class="featured-card">
              <div class="featured-media">
                <img
                  src={featuredArticle.src}
                  width={featuredArticle.width}
                  height={featuredArticle.height}
                  alt=""
                  loading="lazy"
                  decoding="async"
                />
                <span class="sticky-label">置顶</span>
              </div>
              <div class="featured-copy">
                <h3>{featured.data.title}</h3>
                {featured.data.description && <p>{featured.data.description}</p>}
                <div class="article-tags">
                  {featured.data.tags.slice(0, 3).map(tag => (
                    <span>{tag}</span>
                  ))}
                </div>
                <div class="featured-meta">
                  <time datetime={featured.data.publishedAt.toISOString()}>
                    {featured.data.publishedAt.toLocaleDateString('zh-CN')}
                  </time>
                  <span>{calculateReadingTime(featured.body ?? '')} 分钟阅读</span>
                  <span>{countWords(featured.body ?? '')} 字</span>
                </div>
              </div>
              <span class="read-button">阅读全文</span>
            </a>
          </section>
        )}

        <section class="all-section" aria-labelledby="all-heading">
          <h2 id="all-heading" class="section-heading">全部文章</h2>
          {filtered.length === 0 ? (
            <div class="empty-state">
              <h3>还没有文章</h3>
              <p>撰写第一篇之后会出现在这里</p>
            </div>
          ) : regularArticles.length === 0 ? (
            <div class="empty-state">
              <h3>暂无更多文章</h3>
              <p>置顶文章已经显示在上方</p>
            </div>
          ) : (
            <ul class="article-list">
              {regularArticles.map(article => (
                <ArticleListItem article={article} />
              ))}
            </ul>
          )}
        </section>
      </div>

      <aside class="articles-sidebar" aria-label="文章侧栏">
        <section class="side-card search-card">
          <img class="card-cat" src={catCorner.src} width="70" height="70" alt="" loading="lazy" />
          <h2>搜索文章</h2>
          <form class="search-form" role="search" action="/articles" method="get">
            <label class="sr-only" for="article-search">搜索一篇小屋文章</label>
            <input id="article-search" name="q" type="search" placeholder="搜索一篇小屋文章..." />
            <button type="submit" aria-label="搜索">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m21 21-4.35-4.35m1.35-5.65a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z" />
              </svg>
            </button>
          </form>
        </section>

        <section class="side-card stats-card">
          <h2>文章统计</h2>
          <dl>
            <div>
              <dt>文章数</dt>
              <dd>{allArticles.length} 篇</dd>
            </div>
            <div>
              <dt>分类数</dt>
              <dd>{categories.size || tags.length} 个</dd>
            </div>
            <div>
              <dt>总字数</dt>
              <dd>{formatWords(totalWords)} 字</dd>
            </div>
            <div>
              <dt>最近更新</dt>
              <dd>{latestDate}</dd>
            </div>
          </dl>
        </section>

        {tags.length > 0 && (
          <section class="side-card tag-cloud-card">
            <h2>标签云</h2>
            <div class="tag-cloud">
              {tags.map(tag => (
                <a href={`/articles?tag=${encodeURIComponent(tag)}`}>
                  {tag}
                </a>
              ))}
            </div>
          </section>
        )}
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .articles-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 8.25rem 1.75rem 4rem;
  }

  .articles-hero {
    min-height: 390px;
    display: grid;
    grid-template-columns: minmax(280px, 0.78fr) minmax(420px, 1.22fr);
    align-items: center;
    gap: clamp(1.5rem, 4vw, 4rem);
    margin-bottom: 2rem;
  }

  .hero-copy {
    padding-left: clamp(0rem, 2vw, 2rem);
  }

  .hero-kicker {
    margin: 0 0 1.35rem;
    font-size: 1.35rem;
    font-weight: 800;
    color: #10194d;
  }

  .hero-kicker::before {
    content: "";
    display: inline-block;
    width: 14px;
    height: 14px;
    margin-right: 0.6rem;
    border-radius: 3px 9px 3px 9px;
    background: linear-gradient(135deg, #ffb84c, #ffdb7a);
    box-shadow: 0 0 0 5px rgba(255, 197, 86, 0.16);
    vertical-align: 1px;
  }

  .hero-copy h1 {
    margin: 0;
    font-size: clamp(3rem, 6vw, 4.85rem);
    line-height: 1.05;
    font-weight: 900;
    color: #090f42;
    letter-spacing: 0;
  }

  .hero-copy h1::after {
    content: "";
    display: inline-block;
    width: 0.62em;
    height: 0.62em;
    margin-left: 0.25em;
    border: 8px solid rgba(255, 122, 170, 0.74);
    border-radius: 50% 50% 50% 12%;
    transform: rotate(45deg);
    box-shadow: inset 0 0 0 8px rgba(255, 255, 255, 0.7);
  }

  .hero-copy p:not(.hero-kicker) {
    max-width: 31rem;
    margin: 1.65rem 0 0;
    font-size: clamp(1.1rem, 1.6vw, 1.35rem);
    line-height: 1.75;
    font-weight: 600;
    color: #4a568c;
  }

  .hero-image {
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 24px 36px rgba(115, 97, 207, 0.12));
  }

  .articles-content {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 330px;
    gap: 1.35rem;
    align-items: start;
  }

  .articles-main,
  .articles-sidebar {
    display: grid;
    gap: 1.35rem;
  }

  .articles-sidebar {
    position: sticky;
    top: 110px;
  }

  .featured-section,
  .all-section,
  .side-card {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.56)),
      var(--color-surface);
    border: 1px solid rgba(207, 199, 248, 0.82);
    border-radius: 22px;
    box-shadow:
      0 18px 45px rgba(113, 88, 212, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.92);
  }

  .featured-section,
  .all-section {
    padding: 1.2rem;
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 1rem;
    font-size: 1.2rem;
    line-height: 1.2;
    color: #6f48f4;
    font-weight: 850;
  }

  .section-heading::before {
    content: "";
    width: 18px;
    height: 18px;
    border-radius: 5px;
    border: 3px solid currentColor;
    box-shadow: inset 0 0 0 3px rgba(255, 255, 255, 0.72);
  }

  .featured-card {
    position: relative;
    display: grid;
    grid-template-columns: minmax(260px, 0.82fr) minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: center;
    min-height: 214px;
    padding: 0;
    color: inherit;
    text-decoration: none;
  }

  .featured-media {
    position: relative;
    overflow: hidden;
    border-radius: 16px;
    box-shadow: 0 14px 26px rgba(90, 84, 164, 0.16);
  }

  .featured-media img {
    display: block;
    width: 100%;
    aspect-ratio: 257 / 126;
    object-fit: cover;
  }

  .sticky-label {
    position: absolute;
    top: 0.8rem;
    left: 0.8rem;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 800;
    color: #fff;
    background: linear-gradient(135deg, #ff78b5, #ff668c);
    box-shadow: 0 8px 16px rgba(241, 84, 146, 0.22);
  }

  .featured-copy h3 {
    margin: 0;
    font-size: clamp(1.35rem, 2vw, 1.8rem);
    line-height: 1.25;
    font-weight: 900;
    color: #10194d;
  }

  .featured-copy p {
    margin: 0.75rem 0 0;
    max-width: 31rem;
    font-size: 1rem;
    line-height: 1.65;
    font-weight: 600;
    color: #4d5a8f;
  }

  .article-tags,
  .featured-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
  }

  .article-tags {
    gap: 0.7rem;
    margin-top: 0.9rem;
  }

  .article-tags span,
  .tag-cloud a {
    padding: 0.43rem 0.85rem;
    border-radius: 999px;
    background: #efecff;
    color: #673df2;
    font-size: 0.9rem;
    font-weight: 800;
  }

  .article-tags span:nth-child(2n) {
    background: #f4e7ff;
    color: #8a42e8;
  }

  .article-tags span:nth-child(3n) {
    background: #fff0e8;
    color: #f16932;
  }

  .featured-meta {
    gap: 1.15rem;
    margin-top: 1.05rem;
    color: #465487;
    font-size: 0.92rem;
    font-weight: 700;
  }

  .read-button {
    justify-self: end;
    white-space: nowrap;
    padding: 0.78rem 1.25rem;
    border-radius: 999px;
    color: #fff;
    font-weight: 850;
    background: linear-gradient(135deg, #6d7af7, #b33ff0);
    box-shadow: 0 12px 22px rgba(111, 73, 236, 0.28);
    transition: transform var(--duration-fast) var(--easing-default);
  }

  .featured-card:hover .read-button,
  .featured-card:focus-visible .read-button {
    transform: translateY(-1px);
  }

  .article-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .side-card {
    position: relative;
    padding: 1.55rem 1.45rem;
    overflow: hidden;
  }

  .side-card h2 {
    margin: 0 0 1.2rem;
    font-size: 1.25rem;
    color: #10194d;
    font-weight: 900;
  }

  .card-cat {
    position: absolute;
    top: 0.65rem;
    right: 0.6rem;
    width: 64px;
    height: 64px;
    object-fit: contain;
  }

  .search-form {
    position: relative;
  }

  .search-form input {
    width: 100%;
    min-height: 58px;
    border: 1px solid rgba(199, 192, 242, 0.9);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.72);
    color: #10194d;
    padding: 0 3.2rem 0 1rem;
    font: inherit;
    font-weight: 700;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.88),
      0 10px 22px rgba(100, 87, 190, 0.08);
  }

  .search-form input::placeholder {
    color: #8b93c3;
  }

  .search-form button {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    display: grid;
    width: 38px;
    height: 38px;
    place-items: center;
    transform: translateY(-50%);
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: #5962a1;
    cursor: pointer;
  }

  .search-form svg {
    width: 22px;
    height: 22px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.4;
    stroke-linecap: round;
  }

  .stats-card dl {
    display: grid;
    gap: 1.35rem;
    margin: 0;
  }

  .stats-card div {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 1rem;
  }

  .stats-card dt {
    color: #5c669b;
    font-weight: 800;
  }

  .stats-card dd {
    margin: 0;
    color: #10194d;
    font-size: 1.15rem;
    font-weight: 900;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag-cloud a {
    text-decoration: none;
  }

  .empty-state {
    background: rgba(255, 255, 255, 0.58);
    border: 1px dashed rgba(164, 151, 231, 0.55);
    border-radius: 18px;
    padding: 2.5rem 1rem;
    text-align: center;
  }

  .empty-state h3 {
    font-size: 20px;
    font-weight: 800;
    color: var(--color-fg);
    margin: 0 0 0.5rem 0;
  }

  .empty-state p {
    color: var(--color-fg-muted);
    margin: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 1120px) {
    .articles-content {
      grid-template-columns: 1fr;
    }

    .articles-sidebar {
      position: static;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .tag-cloud-card {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 820px) {
    .articles-page {
      padding: 6.25rem 1rem 3rem;
    }

    .articles-hero {
      grid-template-columns: 1fr;
      min-height: 0;
      gap: 1.25rem;
      margin-bottom: 1.25rem;
    }

    .hero-copy {
      padding-left: 0;
    }

    .hero-copy h1 {
      font-size: 2.75rem;
    }

    .hero-image {
      margin-top: -1rem;
    }

    .featured-card {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .read-button {
      justify-self: start;
    }

    .articles-sidebar {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .articles-page {
      padding-left: 0.75rem;
      padding-right: 0.75rem;
    }

    .featured-section,
    .all-section,
    .side-card {
      border-radius: 18px;
    }
  }
</style>
