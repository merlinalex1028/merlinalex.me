---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagChips from '../../components/articles/TagChips.astro';
import ArticleListItem from '../../components/articles/ArticleListItem.astro';
import { extractTags } from '../../utils/tag-extraction';

const allArticles = await getCollection(
  'articles',
  ({ data }) => !data.draft
);

const tags = extractTags(allArticles);
const selectedTag = Astro.url.searchParams.get('tag');

// Sort: sticky first, then newest
const sorted = allArticles.sort((a, b) => {
  if (a.data.sticky !== b.data.sticky) return a.data.sticky ? -1 : 1;
  return b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
});

const filtered = selectedTag
  ? sorted.filter(a => a.data.tags.includes(selectedTag))
  : sorted;
---

<BaseLayout title="文章" description="全部文章 — merlinalex.me" type="website">
  <section class="articles-page">
    <TagChips tags={tags} selected={selectedTag} />

    {filtered.length === 0 ? (
      <div class="empty-state">
        <h3>还没有文章</h3>
        <p>撰写第一篇之后会出现在这里 ✨</p>
      </div>
    ) : (
      <ul class="article-list">
        {filtered.map(article => (
          <ArticleListItem article={article} />
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .articles-page {
    max-width: 768px;
    margin: 0 auto;
    padding: 0 1rem 2rem;
  }

  .article-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .empty-state {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 3rem 1rem;
    text-align: center;
  }

  .empty-state h3 {
    font-size: 20px;
    font-weight: 600;
    color: var(--color-fg);
    margin: 0 0 0.5rem 0;
  }

  .empty-state p {
    color: var(--color-fg-muted);
    margin: 0;
  }
</style>
