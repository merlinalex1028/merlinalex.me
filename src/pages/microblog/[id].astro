---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TwikooComments from '../../components/comments/TwikooComments.astro';

export async function getStaticPaths() {
  const posts = await getCollection('microblog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;

const dateStr = post.data.publishedAt.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

const ARCHIVE_DAYS = 180;
const isArchived =
  Date.now() - post.data.publishedAt.getTime() > ARCHIVE_DAYS * 24 * 60 * 60 * 1000;
---

<BaseLayout title={`说说 — merlinalex.me`} description={post.data.content.slice(0, 100)}>
  <article class="microblog-detail" data-pagefind-filter="exclude">
    <header class="detail-header">
      <time datetime={post.data.publishedAt.toISOString()}>{dateStr}</time>
      {post.data.mood && (
        <span class="mood-badge" aria-label={`心情: ${post.data.mood}`}>
          {post.data.mood}
        </span>
      )}
      {isArchived && <span class="archive-badge">归档</span>}
    </header>

    <div class="detail-content">
      <p>{post.data.content}</p>
    </div>

    {post.data.images.length > 0 && (
      <div class="detail-images">
        {post.data.images.map((src: string) => (
          <img src={src} alt="" loading="lazy" decoding="async" data-zoom />
        ))}
      </div>
    )}

    {post.data.tags.length > 0 && (
      <footer class="detail-tags">
        {post.data.tags.map((tag: string) => (
          <span class="tag-chip">{tag}</span>
        ))}
      </footer>
    )}

    <nav class="detail-nav">
      <a href="/microblog">← 返回说说</a>
    </nav>

    <TwikooComments />
  </article>
</BaseLayout>

<script>
  async function initZoom() {
    const { default: mediumZoom } = await import('medium-zoom');
    mediumZoom('.microblog-detail img[data-zoom]', {
      margin: 24,
      background: 'rgba(0, 0, 0, 0.8)',
    });
  }
  initZoom();
  document.addEventListener('astro:after-swap', initZoom);
</script>

<style>
  .microblog-detail {
    max-width: 640px;
    margin: 0 auto;
    padding: var(--space-xl, 2rem) 1rem;
  }

  .detail-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: var(--space-md, 1rem);
    font-size: 14px;
    color: var(--color-fg-muted);
  }

  .detail-content {
    font-size: 16px;
    line-height: 1.8;
    color: var(--color-fg);
    margin-bottom: var(--space-md, 1rem);
  }

  .detail-content p {
    margin: 0;
  }

  .detail-images {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.5rem;
    margin-bottom: var(--space-md, 1rem);
  }

  .detail-images img {
    width: 100%;
    border-radius: var(--radius-md, 8px);
    cursor: zoom-in;
  }

  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--space-lg, 1.5rem);
  }

  .tag-chip {
    display: inline-block;
    padding: 2px 10px;
    font-size: 12px;
    color: var(--color-accent);
    background: var(--color-accent-subtle);
    border-radius: 9999px;
  }

  .detail-nav {
    margin-top: var(--space-lg, 1.5rem);
    padding-top: var(--space-md, 1rem);
    border-top: 1px solid var(--color-border);
  }

  .detail-nav a {
    color: var(--color-accent);
    text-decoration: none;
    font-size: 14px;
  }

  .detail-nav a:hover {
    text-decoration: underline;
  }

  .mood-badge {
    font-size: 16px;
  }

  .archive-badge {
    font-size: 11px;
    padding: 1px 6px;
    color: var(--color-fg-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
  }
</style>
