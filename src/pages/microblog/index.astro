---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MicroblogCard from '../../components/microblog/MicroblogCard.astro';

const allPosts = await getCollection('microblog');
const sorted = allPosts.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

const PAGE_SIZE = 10;
const initialPosts = sorted.slice(0, PAGE_SIZE);
const hasMore = sorted.length > PAGE_SIZE;

const ARCHIVE_DAYS = 180;
const now = Date.now();

function isArchived(date: Date): boolean {
  return now - date.getTime() > ARCHIVE_DAYS * 24 * 60 * 60 * 1000;
}
---

<BaseLayout title="说说 — merlinalex.me" description="merlinalex.me 的碎碎念">
  <div data-pagefind-filter="exclude" class="microblog-feed">
    <header class="feed-header">
      <h1>说说</h1>
      <p class="feed-subtitle">日常碎碎念，记录生活的小片段</p>
    </header>

    <div class="feed-list" id="microblog-feed">
      {initialPosts.map((post) => (
        <MicroblogCard
          post={post}
          isArchived={isArchived(post.data.publishedAt)}
        />
      ))}
    </div>

    {hasMore && (
      <button class="load-more-btn" id="load-more" type="button">
        加载更多
      </button>
    )}

    <div id="feed-empty" class="feed-empty" hidden>
      <p>还没有说说哦~</p>
    </div>
  </div>
</BaseLayout>

<script>
  const PAGE_SIZE = 10;
  const ARCHIVE_DAYS = 180;

  let allPosts: Array<{
    id: string;
    publishedAt: string;
    content: string;
    mood: string | null;
    tags: string[];
    images: string[];
  }> = [];

  let loadedCount = 0;

  function isArchived(isoDate: string): boolean {
    return Date.now() - new Date(isoDate).getTime() > ARCHIVE_DAYS * 24 * 60 * 60 * 1000;
  }

  function createCardHTML(post: (typeof allPosts)[0]): string {
    const dateStr = new Date(post.publishedAt).toLocaleDateString('zh-CN', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
    });

    const archived = isArchived(post.publishedAt);
    const archivedClass = archived ? ' archived' : '';
    const archiveBadge = archived ? '<span class="archive-badge">归档</span>' : '';
    const moodHTML = post.mood ? `<span class="mood-badge" aria-label="心情: ${post.mood}">${post.mood}</span>` : '';

    const visibleImages = post.images.slice(0, 3);
    const overflowCount = post.images.length - 3;
    const imagesHTML = visibleImages.length > 0
      ? `<div class="card-images">
          ${visibleImages.map((src) => `<img src="${src}" alt="" loading="lazy" decoding="async" data-zoom />`).join('')}
          ${overflowCount > 0 ? `<span class="image-overflow">+${overflowCount}</span>` : ''}
        </div>`
      : '';

    const tagsHTML = post.tags.length > 0
      ? `<footer class="card-tags">${post.tags.map((tag) => `<span class="tag-chip">${tag}</span>`).join('')}</footer>`
      : '';

    return `
      <article class="microblog-card${archivedClass}">
        <header class="card-header">
          <time datetime="${post.publishedAt}">${dateStr}</time>
          ${moodHTML}
          ${archiveBadge}
        </header>
        <p class="card-content">${post.content}</p>
        ${imagesHTML}
        ${tagsHTML}
      </article>
    `;
  }

  async function loadMore() {
    const btn = document.getElementById('load-more');
    if (!btn || allPosts.length === 0) return;

    const nextBatch = allPosts.slice(loadedCount, loadedCount + PAGE_SIZE);
    const feed = document.getElementById('microblog-feed');
    if (!feed) return;

    const fragment = document.createDocumentFragment();
    const temp = document.createElement('div');
    temp.innerHTML = nextBatch.map(createCardHTML).join('');
    while (temp.firstChild) {
      fragment.appendChild(temp.firstChild);
    }
    feed.appendChild(fragment);

    loadedCount += nextBatch.length;

    if (loadedCount >= allPosts.length) {
      btn.hidden = true;
    }

    // Re-init medium-zoom for new images
    const { default: mediumZoom } = await import('medium-zoom');
    mediumZoom('.microblog-card img[data-zoom]', {
      margin: 24,
      background: 'rgba(0, 0, 0, 0.8)',
    });
  }

  async function init() {
    try {
      const res = await fetch('/microblog/data.json');
      if (!res.ok) return;
      allPosts = await res.json();
      loadedCount = PAGE_SIZE; // initial SSR count

      const btn = document.getElementById('load-more');
      if (btn) {
        btn.addEventListener('click', loadMore);
        if (allPosts.length <= PAGE_SIZE) {
          btn.hidden = true;
        }
      }

      // Init medium-zoom for SSR images
      const { default: mediumZoom } = await import('medium-zoom');
      mediumZoom('.microblog-card img[data-zoom]', {
        margin: 24,
        background: 'rgba(0, 0, 0, 0.8)',
      });
    } catch {
      // silent — feed still works with SSR content
    }
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>

<style>
  .microblog-feed {
    max-width: 640px;
    margin: 0 auto;
    padding: var(--space-xl, 2rem) 1rem;
  }

  .feed-header {
    margin-bottom: var(--space-lg, 1.5rem);
  }

  .feed-header h1 {
    font-size: 28px;
    font-weight: 700;
    color: var(--color-fg);
    margin: 0 0 0.25rem 0;
  }

  .feed-subtitle {
    font-size: 14px;
    color: var(--color-fg-muted);
    margin: 0;
  }

  .feed-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm, 0.75rem);
  }

  .load-more-btn {
    display: block;
    width: 100%;
    margin-top: var(--space-md, 1rem);
    padding: 0.75rem 1.5rem;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-surface);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-md, 12px);
    cursor: pointer;
    transition:
      background var(--duration-fast, 150ms) var(--easing-default, ease),
      color var(--duration-fast, 150ms) var(--easing-default, ease);
  }

  .load-more-btn:hover {
    background: var(--color-accent);
    color: #fff;
  }

  .feed-empty {
    text-align: center;
    padding: var(--space-2xl, 3rem) 0;
    color: var(--color-fg-muted);
  }
</style>
